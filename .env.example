# ─────────────────────────────────────────────────────────────────────────────
# MedIntel OS — environment variable reference
# Copy to .env and fill in real values. Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Runtime ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
LOG_LEVEL=info

# ── Clerk authentication ──────────────────────────────────────────────────────
CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...
# Used by the Vite frontend (must be prefixed VITE_ to be exposed to the browser)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/medintel_os

# ── Encryption (AES-256-GCM key for CRM credentials at rest) ─────────────────
# Generate: openssl rand -hex 32
CRM_ENCRYPTION_KEY=hex64chars...

# ── Platform admin ────────────────────────────────────────────────────────────
PLATFORM_ADMIN_EMAIL=admin@example.com

# ── Slack notifications ───────────────────────────────────────────────────────
# Incoming webhook URL for CON-filing alerts (platform-wide fallback).
# Per-account webhook URLs are stored in accounts.settings.slackWebhookUrl.
SLACK_CON_WEBHOOK_URL=https://hooks.slack.com/services/...

# ── CRM / webhook ────────────────────────────────────────────────────────────
PUBLIC_API_BASE_URL=https://your-api-domain.com
PUBLIC_BASE_URL=https://your-app-domain.com
CORS_ORIGINS=https://your-app-domain.com

# HubSpot OAuth
HUBSPOT_OAUTH_CLIENT_ID=
HUBSPOT_OAUTH_CLIENT_SECRET=
HUBSPOT_OAUTH_SCOPES=crm.objects.contacts.write,crm.objects.contacts.read

# Salesforce OAuth
SALESFORCE_OAUTH_CLIENT_ID=
SALESFORCE_OAUTH_CLIENT_SECRET=
SALESFORCE_OAUTH_SCOPES=api,refresh_token

# ── Paid enrichment API keys ──────────────────────────────────────────────────
# SAM.gov API key — register at https://sam.gov/content/entity-information
SAM_GOV_API_KEY=
# FDA OpenFDA API key — optional but raises rate limits (register at open.fda.gov)
FDA_API_KEY=

# Contact validation
ZEROBOUNCE_API_KEY=
BOUNCER_API_KEY=

# ── State CON-filing feed overrides ──────────────────────────────────────────
# Optional: override the default state CON feed URLs.
# Each adapter falls back to a built-in public URL when the env var is unset.
CON_FEED_URL_IL=
CON_FEED_URL_NY=
CON_FEED_URL_FL=
CON_FEED_URL_NC=
CON_FEED_URL_NC_DECISIONS=
CON_FEED_URL_GA=
CON_FEED_URL_MI=
CON_FEED_URL_OH=
# Connecticut OHS CON program — override once CT OHS publishes a stable feed URL
CON_FEED_URL_CT=

# ── Ingestor tuning ───────────────────────────────────────────────────────────
# Minimum match score (0-100) for auto-linking CON filings to facilities
CON_REVIEW_THRESHOLD=

# ── Cron ─────────────────────────────────────────────────────────────────────
# Set to "true" to disable scheduled jobs (useful in test environments)
DISABLE_CRON=false
